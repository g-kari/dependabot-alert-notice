poll_interval: 30m
active_months: 0          # 直近Nか月以内にpushがあったリポのみ対象 (0=無効、例: 6=半年以内)
fetch_min_severity: ""    # 取得する最低重要度 (critical/high/medium、空=全件取得)
disable_approval: false   # true=承認/却下ボタンを無効化して閲覧専用モードにする

targets:
  - owner: your-org
    repo: your-repo
  - owner: your-org
    # repo省略でorg全体

slack:
  channel_id: C0123456789
  # SLACK_BOT_TOKEN, SLACK_APP_TOKEN は環境変数で設定
  allowed_user_ids: []  # 空=全員許可。承認・却下を許可するSlack User ID (U...) のリスト

discord:
  webhook_url: ""  # Discord Webhook URL (環境変数 DISCORD_WEBHOOK_URL でも設定可)

claude_path: claude    # claude CLIのパス
gh_path: gh            # gh CLIのパス
log_level: info        # debug, info, warn, error

web:
  port: 8999

evaluator:
  sandbox:
    enabled: true
    image: dependabot-evaluator:latest
    memory_limit: 512m
    cpu_limit: "0.5"
    timeout: 60s
